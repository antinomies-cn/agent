# 复制为 .env 后再执行 docker compose up -d --build
# 查看状态: docker compose ps
# 更新app service代码：docker compose restart app
# 更新指定文件：docker compose -f docker-compose.yml up -d --build
# 查看容器日志: docker compose logs -f app
# PowerShell 可用: Copy-Item .env.docker.example .env

# 必填: LiteLLM 代理与上游模型配置
# 应用侧会把 OPENAI_* 发给 LiteLLM；LiteLLM 再使用 MIN/DEEP/GLM/BGE/RERANK_* 请求上游。
LITELLM_MASTER_KEY="sk-litellm-dfdfe67038ca80e0bcffefe0660432e360e984b25166f9b2b72f7048607adfbc"
LITELLM_SALT_KEY="EJG2J8XPJGMvUmXNNzaeZuvh3PECKMwrHwalCuFU51z/zSnyDNggf+q5UYsDOcZh"

# 上游 baishan API
MIN_API_KEY="sk-zOmpVAQGhfUhP2Y8Cd4816842651437f9eA01584CbA7959e"
MIN_API_BASE="https://api.edgefn.net/v1"

DEEP_API_KEY="sk-b8FbidQjEzmeF2on7fEa958b7cAd42648299Db28963eA8B8"
DEEP_API_BASE="https://api.edgefn.net/v1"

GLM_API_KEY="sk-b8FbidQjEzmeF2on7fEa958b7cAd42648299Db28963eA8B8"
GLM_API_BASE="https://api.edgefn.net/v1"

BGE_API_KEY="sk-uTvzRwgoLXZdDsgH9983EbEa2eF143FfB7C8F72cC53fA5B3"
BGE_API_BASE="https://api.edgefn.net/v1"

RERANK_API_KEY="sk-1iy8oXs9NX6Vr97Y494bD7D5C8334e748e814e2cA5842911"
RERANK_API_BASE="https://api.edgefn.net/v1"

# 应用连 LiteLLM（compose 内服务名: litellm）
OPENAI_API_KEY="sk-litellm-dfdfe67038ca80e0bcffefe0660432e360e984b25166f9b2b72f7048607adfbc"
OPENAI_API_BASE="http://litellm:4000"
OPENAI_MODEL="MiniMax-M2.5"

# 运行环境
ENV="dev"

# API 服务监听地址
API_HOST="127.0.0.1"
API_PORT="8000"

# LLM 请求重试次数
LLM_RETRY_COUNT="1"

# Embeddings / Rerank（统一走 LiteLLM）
OPENAI_EMBEDDINGS_API_BASE=""
EMBEDDINGS_MODEL="bge-m3"
EMBEDDINGS_DIMENSION="1024"
EMBEDDINGS_TIMEOUT="30"

# 容器启动前执行 Embedding + Rerank 自检（建议保持 true）
EMBEDDINGS_STARTUP_CHECK="true"
RERANK_ENABLED="true"
RERANK_MODEL="bge-reranker"
RERANK_UPSTREAM_MODEL="bge-reranker-v2-m3"
RERANK_DIRECT_UPSTREAM="true"
RERANK_TIMEOUT="15"
RERANK_TOP_N=""
RERANK_STARTUP_STRICT="false"

# Web抓取SSL校验（建议保持 true）
WEB_LOADER_VERIFY_SSL="false"

# 向量检索
VECTOR_SEARCH_TOP_K="4"

# 可选: 构建期 pip 网络参数（网络不稳定时建议配置国内镜像）
PIP_INDEX_URL="https://pypi.tuna.tsinghua.edu.cn/simple"
PIP_TRUSTED_HOST="pypi.tuna.tsinghua.edu.cn"
PIP_DEFAULT_TIMEOUT="240"
PIP_RETRIES="10"

# Redis（与 compose 中默认值一致，可按需修改）
REDIS_URL=""
REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"
REDIS_DB="0"
REDIS_PASSWORD="64588515"

# 会话记忆
MEMORY_TTL="86400"
MEMORY_COMPACT_MESSAGE_COUNT="10"
MOOD_TIMEOUT_SECONDS="5"

# Qdrant
QDRANT_URL="http://qdrant:6333"
QDRANT_API_KEY="64588515"
QDRANT_COLLECTION="web_collection"
QDRANT_DB_PATH="./qdrant_data/qdrant.db"
QDRANT_DISTANCE="cosine"

# 可选: 搜索/占星
SERPAPI_API_KEY="a08341eb46eac1a5fa93d40c7ad48cbc737f32697cccf4c4b0a29c90aeb9f8c1"
XINGPAN_API_URL="https://cloud.apiworks.com/open/astro"
XINGPAN_APP_ID="APP_1775647418315A47DD"
XINGPAN_APP_KEY="1fe5af1210f44a7a8bc1a1d9a12a6d9c"
XINGPAN_TIMEOUT="15"
ASTRO_UID="U_4eW9t3"
ASTRO_BIRTH_DT="1999-10-17 21:00:00"
ASTRO_LONGITUDE="116.4074"
ASTRO_LATITUDE="39.9042"

# 日志
