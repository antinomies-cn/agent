# 复制为 .env 后再执行 docker compose up -d --build
# 查看状态: docker compose ps
# PowerShell 可用: Copy-Item .env.docker.example .env

# 必填: 大模型网关配置
OPENAI_API_KEY="sk-zOmpVAQGhfUhP2Y8Cd4816842651437f9eA01584CbA7959e"
OPENAI_API_BASE="https://api.edgefn.net"
OPENAI_MODEL="MiniMax-M2.5"

# Embeddings 专用本地配置（add_urls / vector_search 仅读取 EMBEDDINGS_*）
EMBEDDINGS_API="local"
EMBEDDINGS_MODEL="/app/model_cache/BAAI/bge-small-zh-v1.5"
EMBEDDINGS_DIMENSION="512"

# 若容器无法访问 huggingface.co，可开启离线模式并使用本地缓存模型
EMBEDDINGS_LOCAL_FILES_ONLY="true"

# 容器启动前执行Embedding自检（建议保持 true）
EMBEDDINGS_STARTUP_CHECK="true"

# 可选: HuggingFace 镜像（示例: https://hf-mirror.com）
EMBEDDINGS_HF_ENDPOINT="https://hf-mirror.com"

# 可选: 模型缓存目录（容器内路径）
EMBEDDINGS_CACHE_DIR="/app/model_cache"

# Web抓取SSL校验（建议保持 true）
WEB_LOADER_VERIFY_SSL="false"

# 可选: 构建期 pip 网络参数（网络不稳定时建议配置国内镜像）
PIP_INDEX_URL="https://pypi.tuna.tsinghua.edu.cn/simple"
PIP_TRUSTED_HOST="pypi.tuna.tsinghua.edu.cn"
PIP_DEFAULT_TIMEOUT="240"
PIP_RETRIES="10"

# Redis（与 compose 中默认值一致，可按需修改）
REDIS_PASSWORD="64588515"

# Qdrant
QDRANT_URL="http://qdrant:6333"
QDRANT_API_KEY="64588515"

# 可选: 搜索/占星
SERPAPI_API_KEY="a08341eb46eac1a5fa93d40c7ad48cbc737f32697cccf4c4b0a29c90aeb9f8c1"
XINGPAN_APP_ID="APP_17744300994775B6A4"
XINGPAN_APP_KEY="7de86419e6b84aaa84625dcdf25d637b"
ASTRO_UID="U_4eW9t3"
